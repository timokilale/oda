# ── Backend (Laravel) ──────────────────────────────────
APP_URL=http://localhost:8000
PUBLIC_APP_URL=http://localhost:8000
FILESYSTEM_DISK=local

# ── Database ───────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=oda_cloud

# ── OTP / Auth ─────────────────────────────────────────
AUTH_TOKEN_COOKIE_NAME=oda_owner_token
AUTH_TOKEN_TTL_DAYS=30
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_WINDOW_MINUTES=15
OTP_MAX_REQUESTS_PER_WINDOW=3
OTP_MAX_REQUESTS_PER_IP_WINDOW=10
EXPOSE_DEV_OTP=false
